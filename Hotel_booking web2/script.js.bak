let fetchedRooms = [];

const fetchRooms = async () => {
    try {
        const response = await fetch(`${API_BASE}/api/rooms`);
        if (!response.ok) throw new Error('Failed to fetch rooms');
        const rooms = await response.json();
        if (rooms && rooms.length > 0) {
            fetchedRooms = rooms;
            renderRoomGrid(rooms);
            renderRoomSelect(rooms);
        } else {
            throw new Error('No rooms available');
        }
    } catch (error) {
        console.log('Using static rooms data due to:', error.message);
        fetchedRooms = staticRooms;
        renderRoomGrid(staticRooms);
        renderRoomSelect(staticRooms);
    }
};

function renderRoomSelect(rooms) {
    if (!roomSelect) return;
    roomSelect.innerHTML = '<option value="" disabled selected>Select a room</option>';
    rooms.forEach(r => {
        const opt = document.createElement('option');
        opt.value = r._id;
        opt.textContent = `${r.name} - ₹${r.pricePerNight}/night`;
        roomSelect.appendChild(opt);
    });
    appendSubtypeOptions(roomSelect, rooms);
    syncBnRoomOptions();
}

function syncBnRoomOptions() {
    if (!bnRoom) return;
    bnRoom.innerHTML = '<option value="" disabled selected>Select a room</option>';
    fetchedRooms.forEach(r => {
        const opt = document.createElement('option');
        opt.value = r._id;
        opt.textContent = `${r.name} - ₹${r.pricePerNight}/night`;
        bnRoom.appendChild(opt);
    });
    appendSubtypeOptions(bnRoom, fetchedRooms);
}

// Add sub-rooms under each type, using the parent roomId as value
function appendSubtypeOptions(selectEl, rooms) {
    const byType = {};
    rooms.forEach(r => { byType[String(r.type).toLowerCase()] = r; });

    const subtypes = {
        standard: [
            { label: 'Cozy Queen Room' },
            { label: 'City View Twin' },
            { label: 'Classic King Room' },
            { label: 'Standard Double' },
            { label: 'Compact Solo Room' }
        ],
        deluxe: [
            { label: 'Deluxe King with Balcony' },
            { label: 'Ocean View Deluxe' },
            { label: 'Family Deluxe Room' },
            { label: 'Deluxe Twin with View' },
            { label: 'Corner King Deluxe' }
        ],
        suite: [
            { label: 'Presidential Suite' },
            { label: 'Terrace Suite' },
            { label: 'Panoramic Suite' },
            { label: 'Junior Suite' },
            { label: 'Executive Family Suite' }
        ]
    };

    // Clear existing options except the first one (if it's a placeholder)
    if (selectEl.options.length > 0 && selectEl.options[0].value === '') {
        selectEl.innerHTML = '';
        selectEl.innerHTML = '<option value="" disabled selected>Select a room</option>';
    } else {
        selectEl.innerHTML = '<option value="" disabled selected>Select a room</option>';
    }

    // Add main room options
    rooms.forEach(room => {
        const opt = document.createElement('option');
        opt.value = room._id;
        opt.textContent = `${room.name} - ₹${room.pricePerNight}/night`;
        selectEl.appendChild(opt);
    });

    // Add sub-type options
    Object.entries(byType).forEach(([type, room]) => {
        const typeSubtypes = subtypes[type] || [];
        typeSubtypes.forEach((subtype, index) => {
            const opt = document.createElement('option');
            opt.value = room._id; // Use parent room ID as value
            opt.textContent = `↳ ${subtype.label}`; // Indent sub-options for better UX
            selectEl.appendChild(opt);
        });
    });
}

    // Function to sync room options in the booking form
function syncBnRoomOptions() {
    const bnRoom = document.getElementById('bn-room');
    if (!bnRoom) return;
    
    // Clear existing options
    bnRoom.innerHTML = '<option value="" disabled selected>Select a room</option>';
    
    // Add main room options
    if (window.fetchedRooms && Array.isArray(window.fetchedRooms)) {
        window.fetchedRooms.forEach(room => {
            const opt = document.createElement('option');
            opt.value = room._id;
            opt.textContent = `${room.name} - ₹${room.pricePerNight}/night`;
            bnRoom.appendChild(opt);
        });
        
        // Add sub-type options
        appendSubtypeOptions(bnRoom, window.fetchedRooms);
    }

        Object.keys(subtypes).forEach(type => {
            const parent = byType[type];
            if (!parent) return;
            const group = document.createElement('optgroup');
            group.label = `${parent.name} — Sub rooms`;
            subtypes[type].forEach(s => {
                const opt = document.createElement('option');
                opt.value = parent._id; // map to parent room id for pricing/booking
                opt.textContent = `${s.label} (${parent.name})`;
                group.appendChild(opt);
            });
            selectEl.appendChild(group);
        });
    }

    function renderRoomGrid(rooms) {
        if (!roomGrid) return;
        roomGrid.innerHTML = '';
        
        if (!Array.isArray(rooms) || rooms.length === 0) {
            const noRoomsCard = document.createElement('div');
            noRoomsCard.className = 'no-rooms';
            noRoomsCard.innerHTML = `
                <h3>No rooms available</h3>
                <p>Please try different search criteria</p>
            `;
            roomGrid.appendChild(noRoomsCard);
            return;
        }
        
        // Ensure rooms is an array before forEach
        const roomsArray = Array.isArray(rooms) ? rooms : [];
        roomsArray.forEach(r => {
            const card = document.createElement('div');
            card.className = 'room-card';
            const imgSrc = (r.images && r.images[0]) || './images/standard_room.jpg';
            const detailsHref = getRoomDetailsHref(r.type);
            card.innerHTML = `
                <div class="room-image">
                    <img src="${imgSrc}" alt="${r.name}">
                </div>
                <div class="room-content">
                    <div class="room-rating">★★★★☆<span>${r.type}</span></div>
                    <h3>${r.name}</h3>
                    <p class="room-description">Capacity: ${r.capacity} • ₹${r.pricePerNight}/night</p>
                    <div class="price-action">
                        <button class="btn btn-secondary" data-room-id="${r._id}">Select</button>
                        ${detailsHref ? `<a class="btn btn-secondary" style="margin-left:6px;" href="${detailsHref}">View Details</a>` : ''}
                    </div>
                </div>`;
            roomGrid.appendChild(card);
        });

        // Attach select buttons: set the dropdown value and open booking modal
        roomGrid.querySelectorAll('button[data-room-id]').forEach(btn => {
            btn.addEventListener('click', () => {
                const selectedId = btn.getAttribute('data-room-id');
                if (roomSelect) roomSelect.value = selectedId;
                if (bnRoom) {
                    syncBnRoomOptions();
                    bnRoom.value = selectedId;
                }
                const token = localStorage.getItem('token');
                if (!token) {
                    showMessage('Please login to book.', 'error');
                    showModal(loginModal);
                    return;
                }
                // Pre-fill dates/guests
                if (bnCheckin && document.getElementById('checkin')) bnCheckin.value = document.getElementById('checkin').value;
                if (bnCheckout && document.getElementById('checkout')) bnCheckout.value = document.getElementById('checkout').value;
                if (bnGuests && document.getElementById('guests')) bnGuests.value = document.getElementById('guests').value || 2;
                // Build per-guest ID upload inputs
                buildIdProofInputs();
                resetCustomers();
                showModal(bookNowModal);
            });
        });
    }

    function getRoomDetailsHref(type) {
        if (!type) return '';
        const t = String(type).toLowerCase();
        if (t === 'standard') return 'standard_room.html';
        if (t === 'deluxe') return 'delux_room.html';
        if (t === 'suite') return 'executive_suite.html';
        return '';
    }

    fetchRooms();

    // Function to update the room selection dropdown
    function updateRoomDropdown(rooms) {
        const roomSelect = document.getElementById('bn-room');
        if (!roomSelect) return;
        
        // Clear existing options except the first one
        while (roomSelect.options.length > 1) {
            roomSelect.remove(1);
        }
        
        // Add rooms to the dropdown
        rooms.forEach(room => {
            const option = document.createElement('option');
            option.value = room._id;
            option.textContent = `${room.type} - Rs.${room.price}/night`;
            option.dataset.price = room.price;
            option.dataset.maxGuests = room.maxGuests || 2;
            roomSelect.appendChild(option);
        });
        
        // Update guests max based on selected room
        roomSelect.addEventListener('change', function() {
            const selectedOption = this.options[this.selectedIndex];
            if (selectedOption && selectedOption.dataset.maxGuests) {
                const guestsInput = document.getElementById('bn-guests');
                if (guestsInput) {
                    guestsInput.max = selectedOption.dataset.maxGuests;
                    if (parseInt(guestsInput.value) > parseInt(guestsInput.max)) {
                        guestsInput.value = guestsInput.max;
                    }
                }
            }
        });
    }
    
    // Function to load rooms and populate the room selection dropdown
    async function loadRoomsFromHTML() {
        try {
            // First try to get rooms from the backend API
            try {
                const response = await fetch(`${API_BASE}/api/rooms`);
                if (response.ok) {
                    const rooms = await response.json();
                    // Update the room dropdown
                    updateRoomDropdown(rooms);
                    return rooms.map(room => ({
                        _id: room._id,
                        type: room.name || room.type || 'Room',
                        price: room.pricePerNight || 0,
                        description: room.description || '',
                        image: room.image || '',
                        maxGuests: room.capacity || 2,
                        available: room.available || 0
                    }));
                }
            } catch (error) {
                console.log('Using fallback room data from HTML');
            }
            
            // If API fails, fall back to parsing the HTML
            const htmlResponse = await fetch('rooms.html');
            const html = await htmlResponse.text();
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            
            const rooms = [];
            const roomCards = doc.querySelectorAll('.detailed-room-card');
            
            roomCards.forEach((card, index) => {
                const title = card.querySelector('h3')?.textContent.trim() || `Room ${index + 1}`;
                const priceText = card.querySelector('.room-meta span:first-child')?.textContent || '';
                const price = priceText.match(/Rs\.([\d,]+)/)?.[1]?.replace(/,/g, '') || '0';
                const beds = card.querySelector('.room-meta span:last-child')?.textContent.replace('Beds:', '').trim() || '';
                const image = card.querySelector('img')?.src || '';
                
                // Generate a temporary ID (this will only be used if backend is not available)
                const tempId = `temp-${Date.now()}-${index}`;
                
                rooms.push({
                    _id: tempId,
                    type: title,
                    price: parseInt(price),
                    description: beds,
                    image: image,
                    maxGuests: 2,
                    available: 1,
                    isTemporary: true // Mark as temporary since it's not from the backend
                });
            });
            
            // Update the room dropdown with HTML rooms
            updateRoomDropdown(rooms);
            return rooms;
        } catch (error) {
            console.error('Error loading rooms:', error);
            return [];
        }
    }

        // Test receipt function - can be called from browser console
    window.testReceipt = function() {
        const testBooking = {
            _id: 'test123',
            checkIn: new Date().toISOString(),
            checkOut: new Date(Date.now() + 86400000 * 3).toISOString(), // 3 days from now
            guests: 2,
            contact: {
                name: 'Test User',
                email: 'test@example.com',
                phone: '1234567890'
            },
            room: {
                price: 5000
            }
        };
        showBookingReceipt(testBooking, 'Deluxe Room');
    };

    // --- Auth bootstrap (keep user logged in) ---
    async function bootstrapAuth() {
        const token = localStorage.getItem('token');
        if (!token) {
            updateAuthUI(null);
            return;
        }
        try {
            const res = await fetch(`${API_BASE}/api/auth/me`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (!res.ok) throw new Error('Unauthorized');
            const data = await res.json();
            updateAuthUI(data.user);
        } catch {
            localStorage.removeItem('token');
            updateAuthUI(null);
        }
    }

    function updateAuthUI(user) {
        if (!userDisplay || !logoutLink) return;
        if (user && user.username) {
            userDisplay.textContent = `Hi, ${user.username}`;
            userDisplay.classList.remove('hidden');
            logoutLink.classList.remove('hidden');
            loginLink.classList.add('hidden');
            registerLink.classList.add('hidden');
            // Only show Admin link for admins
            if (adminLink) {
                if (user.isAdmin) adminLink.classList.remove('hidden');
                else adminLink.classList.add('hidden');
            }
            if (bookingsLink) bookingsLink.classList.remove('hidden');
        } else {
            userDisplay.textContent = '';
            userDisplay.classList.add('hidden');
            logoutLink.classList.add('hidden');
            loginLink.classList.remove('hidden');
            registerLink.classList.remove('hidden');
            if (adminLink) adminLink.classList.add('hidden');
            if (bookingsLink) bookingsLink.classList.add('hidden');
        }
    }

    bootstrapAuth();

    // --- Search submits: show rooms only ---
    if (bookingForm) {
        bookingForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const guests = parseInt(document.getElementById('guests').value, 10);
            const checkIn = document.getElementById('checkin').value;
            const checkOut = document.getElementById('checkout').value;
            
            console.log('Searching rooms for', guests, 'guests');
            
            // If guests exceed max single-room capacity, suggest multiple rooms
            const maxCapacity = Math.max(...fetchedRooms.map(r => r.capacity));
            if (guests > maxCapacity) {
                showMessage('For more than 4 guests, please book multiple rooms.', 'error');
            }

            // Filter rooms based on guest capacity
            const availableRooms = fetchedRooms.filter(room => room.capacity >= Math.min(guests, maxCapacity));
            console.log('Available rooms:', availableRooms);
            
            // Update the room grid with filtered rooms
            renderRoomGrid(availableRooms);
            
            // Scroll to rooms section
            document.getElementById('rooms')?.scrollIntoView({ behavior: 'smooth' });

            // Update ID proof helper in modal to indicate required count now, too
            // Sync the ID proof inputs/helper now as well
            buildIdProofInputs();
        });
    }

    // Build/Rebuild the per-guest ID proof inputs based on current bnGuests value
    function buildIdProofInputs() {
        const idHelpEl = document.getElementById('id-proof-help');
        const idListEl = document.getElementById('id-proof-list');
        if (!bnGuests || !idListEl) return;
        const count = parseInt(bnGuests.value, 10) || 1;
        if (idHelpEl) idHelpEl.textContent = `Upload clear photos of IDs for all guests (${count} required). Max 5MB each.`;
        idListEl.innerHTML = '';
        for (let i = 0; i < count; i++) {
            const row = document.createElement('div');
            row.style.display = 'flex';
            row.style.alignItems = 'center';
            row.style.gap = '8px';
            row.style.marginBottom = '8px';
            row.innerHTML = `
                <label style=\"min-width:120px;\">Guest ${i+1} ID</label>
                <input type=\"file\" accept=\"image/*\" data-id-proof=\"${i}\">`;
            idListEl.appendChild(row);
        }
    }

    // If the user changes the Guests field inside the modal, regenerate inputs
    if (bnGuests) {
        bnGuests.addEventListener('input', buildIdProofInputs);
        bnGuests.addEventListener('change', buildIdProofInputs);
    }

    // --- Book Now modal submit ---
    if (bookNowForm) {
        bookNowForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            // Get form values
            const roomSelect = document.getElementById('bn-room');
            const roomId = roomSelect.value;
            const selectedRoom = roomSelect.options[roomSelect.selectedIndex];
            const roomName = selectedRoom ? selectedRoom.text.split(' - ')[0] : 'Selected Room';
            
            const checkIn = bnCheckin.value;
            const checkOut = bnCheckout.value;
            const guests = parseInt(bnGuests.value, 10);
            const fullName = bnFullname.value.trim();
            const email = bnEmail.value.trim();
            const phone = bnPhone.value.trim();
            
            // Basic validation
            if (!roomId || roomId === '' || roomId === 'select') {
                showMessage('Please select a room', 'error');
                return;
            }
            
            if (!checkIn || !checkOut) {
                showMessage('Please select check-in and check-out dates', 'error');
                return;
            }
            
            if (new Date(checkIn) >= new Date(checkOut)) {
                showMessage('Check-out date must be after check-in date', 'error');
                return;
            }
            
            if (!guests || guests < 1) {
                showMessage('Please enter a valid number of guests', 'error');
                return;
            }
            
            if (!fullName || !email || !phone) {
                showMessage('Please fill in all contact details', 'error');
                return;
            }
            
            // Validate email format
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(email)) {
                showMessage('Please enter a valid email address', 'error');
                return;
            }
            
            const contact = { fullName, email, phone };
            const customers = collectCustomers();
            
            // Collect per-guest files
            const idList = document.getElementById('id-proof-list');
            const idInputs = idList ? Array.from(idList.querySelectorAll('input[type="file"][data-id-proof]')) : [];
            const idFiles = [];
            idInputs.forEach(inp => { if (inp.files && inp.files[0]) idFiles.push(inp.files[0]); });
            
            // Validate that the number of entered customer names matches guests - 1 (excluding self)
            const requiredAdditionalGuests = Math.max(0, guests - 1);
            if (customers.length < requiredAdditionalGuests) {
                const remaining = requiredAdditionalGuests - customers.length;
                showMessage(`Please add names for all guests. ${remaining} more ${remaining === 1 ? 'guest' : 'guests'} required.`, 'error');
                return;
            }

            // Validate identity proofs count
            const totalGuests = guests;
            if (idFiles.length < totalGuests) {
                const remainIds = totalGuests - idFiles.length;
                showMessage(`Please upload identity proof photos for all guests. ${remainIds} more required.`, 'error');
                return;
            }
            
            const token = localStorage.getItem('token');
            if (!token) {
                showMessage('Please login to book.', 'error');
                showModal(loginModal);
                return;
            }
            
            // Show loading state
            const submitBtn = e.target.querySelector('button[type="submit"]');
            const originalBtnText = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Processing...';
            
            try {
                console.log('Starting booking process...');
                const selectedSubroom = bnSubroom?.value || '';
                console.log('Calling createBooking with:', { roomId, checkIn, checkOut, guests, contact });
                const result = await createBooking(roomId, checkIn, checkOut, guests, contact, customers, selectedSubroom, idFiles);
                console.log('createBooking result:', result);
                
                if (result) {
                    console.log('Booking successful, redirecting to receipt page...');
                    
                    // Get the booking data
                    const bookingData = result.booking || result;
                    const checkInDate = bookingData.checkIn || checkIn;
                    const checkOutDate = bookingData.checkOut || checkOut;
                    const roomPrice = selectedRoom ? (selectedRoom.dataset.price || 0) : 0;
                    
                    // Build the URL with booking details
                    const params = new URLSearchParams({
                        id: bookingData._id || 'temp-' + Date.now(),
                        room: roomName || 'Standard Room',
                        checkIn: checkInDate,
                        checkOut: checkOutDate,
                        guests: guests,
                        name: fullName,
                        email: email,
                        phone: phone,
                        rate: roomPrice
                    });
                    
                    // Reset the form and hide modal
                    bookNowForm.reset();
                    hideModal(bookNowModal);
                    
                    // Redirect to receipt page
                    window.location.href = `receipt.html?${params.toString()}`;
                } else {
                    showMessage((result && result.message) || 'Booking failed. Please try again.', 'error');
                }
            } catch (err) {
                console.error('Booking error:', err);
                showMessage(err?.message || 'An error occurred while processing your booking.', 'error');
            } finally {
                // Reset button state
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnText;
            }
        });
    }

    // Aadhaar Verification Section
    const aadhaarForm = document.getElementById('aadhaar-verification');
    const aadhaarInput = document.getElementById('aadhaar-number');
    const verifyAadhaarBtn = document.getElementById('verify-aadhaar');
    const otpSection = document.getElementById('otp-verification');
    const verifyOtpBtn = document.getElementById('verify-otp');
    const otpInput = document.getElementById('otp');
    const resendOtpBtn = document.getElementById('resend-otp');
    
    // Store OTP for verification
    let currentOtp = '';
    let aadhaarNumber = '';
    
    // Generate random 6-digit OTP
    function generateOTP() {
        return Math.floor(100000 + Math.random() * 900000).toString();
    }
    
    // Send OTP to the registered mobile number (simulated)
    function sendOTP(aadhaar) {
        currentOtp = generateOTP();
        console.log(`[Aadhaar Verification] OTP for ${aadhaar}: ${currentOtp}`);
        // In production, this would be an API call to send OTP to the registered mobile
    }
    
    // Verify Aadhaar button click handler
    if (verifyAadhaarBtn) {
        verifyAadhaarBtn.addEventListener('click', () => {
            aadhaarNumber = aadhaarInput.value.trim();
            
            // Simple Aadhaar validation (12 digits)
            if (!/^\d{12}$/.test(aadhaarNumber)) {
                alert('Please enter a valid 12-digit Aadhaar number');
                return;
            }
            
            // Show OTP section and send OTP
            otpSection.style.display = 'block';
            verifyAadhaarBtn.disabled = true;
            sendOTP(aadhaarNumber);
            
            // Start resend timer
            let timeLeft = 30;
            resendOtpBtn.disabled = true;
            const timer = setInterval(() => {
                timeLeft--;
                resendOtpBtn.textContent = `Resend OTP (${timeLeft}s)`;
                
                if (timeLeft <= 0) {
                    clearInterval(timer);
                    resendOtpBtn.disabled = false;
                    resendOtpBtn.textContent = 'Resend OTP';
                }
            }, 1000);
        });
    }
    
    // Verify OTP button click handler
    if (verifyOtpBtn) {
        verifyOtpBtn.addEventListener('click', () => {
            const enteredOtp = otpInput.value.trim();
            
            if (enteredOtp === currentOtp) {
                alert('Aadhaar verified successfully!');
                document.getElementById('aadhaar-verified').value = 'true';
                document.getElementById('customer-section').style.display = 'block';
                otpSection.style.display = 'none';
                
                // Update verify button to show verified state
                const verifyBtn = document.getElementById('verify-aadhaar');
                verifyBtn.textContent = '✓ Verified';
                verifyBtn.disabled = true;
                verifyBtn.classList.remove('btn-secondary');
                verifyBtn.classList.add('btn-verified');
            } else {
                alert('Invalid OTP. Please try again.');
            }
        });
    }
    
    // Resend OTP button click handler
    if (resendOtpBtn) {
        resendOtpBtn.addEventListener('click', () => {
            if (aadhaarNumber) {
                sendOTP(aadhaarNumber);
                alert('New OTP sent!');
            }
        });
    }

    // Customer rows
    if (addCustomerBtn) {
        addCustomerBtn.addEventListener('click', () => {
            if (document.getElementById('aadhaar-verified').value !== 'true') {
                alert('Please verify your Aadhaar first');
                return;
            }
            addCustomerRow();
        });
    }
    function addCustomerRow() {
        if (!customersList) return;
        const row = document.createElement('div');
        row.className = 'customer-row';
        row.innerHTML = `
            <div class="form-group name-col">
                <input type="text" placeholder="Full Name" data-field="name" required>
            </div>
            <div class="form-group age-col">
                <input type="number" placeholder="Age" data-field="age" min="1" max="120" required>
            </div>
            <div class="form-group gender-col">
                <select data-field="gender" required>
                    <option value="">Gender</option>
                    <option value="Male">Male</option>
                    <option value="Female">Female</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div class="form-group actions-col">
                <button type="button" class="remove-customer" title="Remove guest">×</button>
            </div>
        `;
        const removeBtn = row.querySelector('.remove-customer');
        if (removeBtn) {
            removeBtn.addEventListener('click', () => row.remove());
        }
        customersList.appendChild(row);
    }
    function resetCustomers() {
        if (!customersList) return;
        customersList.innerHTML = '';
        addCustomerRow();
    }
    function collectCustomers() {
        const rows = customersList ? Array.from(customersList.querySelectorAll('.customer-row')) : [];
        return rows.map(row => {
            const genderSelect = row.querySelector('[data-field="gender"]');
            const idTypeSelect = row.querySelector('[data-field="idType"]');
            
            return {
                name: row.querySelector('[data-field="name"]')?.value || '',
                age: parseInt(row.querySelector('[data-field="age"]')?.value, 10) || 0,
                gender: genderSelect ? genderSelect.value : 'Other',
                idType: idTypeSelect ? idTypeSelect.value : null,
                idNumber: row.querySelector('[data-field="idNumber"]')?.value || '',
                relation: row.querySelector('[data-field="relation"]')?.value || 'Other'
            };
        }).filter(customer => customer.name.trim() !== ''); // Only include customers with names
    }

    // --- Admin Create Room ---
    if (adminRoomForm) {
        adminRoomForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const token = localStorage.getItem('token');
            if (!token) {
                showMessage('Please login to create rooms.', 'error');
                return;
            }

            const name = document.getElementById('room-name').value;
            const type = document.getElementById('room-type').value;
            const capacity = parseInt(document.getElementById('room-capacity').value, 10);
            const pricePerNight = parseInt(document.getElementById('room-price').value, 10);
            const amenitiesStr = document.getElementById('room-amenities').value;
            const imagesStr = document.getElementById('room-images').value;
            const description = document.getElementById('room-description').value;

            const amenities = amenitiesStr ? amenitiesStr.split(',').map(s => s.trim()).filter(Boolean) : [];
            const images = imagesStr ? imagesStr.split(',').map(s => s.trim()).filter(Boolean) : [];

            try {
                const res = await fetch(`${API_BASE}/api/rooms`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({ name, type, capacity, pricePerNight, amenities, images, description })
                });
                const data = await res.json().catch(() => ({}));
                if (res.status === 401) {
                    localStorage.removeItem('token');
                    showMessage('Please login to create rooms.', 'error');
                    showModal(loginModal);
                } else if (res.ok) {
                    showMessage('Room created.', 'success');
                    hideModal(adminModal);
                    adminRoomForm.reset();
                    fetchRooms();
                } else {
                    showMessage(data.message || 'Failed to create room', 'error');
                }
            } catch (err) {
                showMessage('Network error. Please try again.', 'error');
            }
        });
    }

    // --- Admin Dashboard Logic ---
    async function loadAdminDashboard() {
        const token = localStorage.getItem('token');
        if (!token) return;
        try {
            const res = await fetch(`${API_BASE}/api/bookings/admin/summary`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (!res.ok) return;
            const data = await res.json();
            setText('stat-total-rooms', data.totalRooms);
            setText('stat-total-bookings', data.totalBookings);
            setText('stat-active-bookings', data.activeBookings);
            setText('stat-needs-cleaning', data.roomsNeedingCleaning);

            // Also fetch rooms needing cleaning to list
            const roomsRes = await fetch(`${API_BASE}/api/rooms`);
            const roomsData = await roomsRes.json();
            const needing = (roomsData.rooms || []).filter(r => r.needsCleaning);
            renderCleaningList(needing);

            // Load bookings per room chart with optional date filters
            const { from, to } = getStatsRange();
            const qs = new URLSearchParams();
            if (from) qs.set('from', from);
            if (to) qs.set('to', to);
            const statsRes = await fetch(`${API_BASE}/api/bookings/admin/stats?${qs.toString()}`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const statsData = await statsRes.json();
            renderBookingsChart(statsData.byRoom, roomsData.rooms || []);

            // Render rooms table
            renderRoomsTable(roomsData.rooms || []);
        } catch {}
    }

    function setText(id, value) {
        const el = document.getElementById(id);
        if (el) el.textContent = String(value);
    }

    function renderCleaningList(rooms) {
        const list = document.getElementById('cleaning-list');
        if (!list) return;
        list.innerHTML = '';
        rooms.forEach(r => {
            const li = document.createElement('li');
            li.textContent = `${r.name} (${r.type})`;
            const btn = document.createElement('button');
            btn.textContent = 'Mark Cleaned';
            btn.className = 'btn btn-secondary';
            btn.style.marginLeft = '8px';
            btn.addEventListener('click', () => markCleaned(r._id));
            li.appendChild(btn);
            list.appendChild(li);
        });
    }

    async function markCleaned(roomId) {
        const token = localStorage.getItem('token');
        try {
            const res = await fetch(`${API_BASE}/api/rooms/${roomId}/cleaning`, {
                method: 'PATCH',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify({ needsCleaning: false })
            });
            if (res.ok) {
                showMessage('Room marked as cleaned.', 'success');
                loadAdminDashboard();
            } else if (res.status === 401) {
                localStorage.removeItem('token');
                showMessage('Session expired. Please login again.', 'error');
                showModal(loginModal);
            } else {
                showMessage('Failed to update room.', 'error');
            }
        } catch {
            showMessage('Network error.', 'error');
        }
    }

    function getStatsRange() {
        const fromEl = document.getElementById('stats-from');
        const toEl = document.getElementById('stats-to');
        return { from: fromEl && fromEl.value ? fromEl.value : null, to: toEl && toEl.value ? toEl.value : null };
    }

    const statsApply = document.getElementById('stats-apply');
    if (statsApply) {
        statsApply.addEventListener('click', () => loadAdminDashboard());
    }

    // Minimal chart renderer without external libs
    function renderBookingsChart(byRoom, allRooms) {
        const canvas = document.getElementById('bookings-chart');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        const labels = byRoom.map(x => {
            const r = allRooms.find(ar => String(ar._id) === String(x._id));
            return r ? r.name : x._id;
        });
        const values = byRoom.map(x => x.count);
        const max = Math.max(1, ...values);
        const barWidth = Math.max(20, Math.floor((canvas.width - 40) / Math.max(1, values.length)) - 10);
        labels.forEach((label, i) => {
            const x = 30 + i * (barWidth + 10);
            const h = Math.round((values[i] / max) * (canvas.height - 50));
            const y = canvas.height - 20 - h;
            ctx.fillStyle = '#2b6cb0';
            ctx.fillRect(x, y, barWidth, h);
            ctx.fillStyle = '#000';
            ctx.font = '12px sans-serif';
            ctx.fillText(String(values[i]), x + barWidth / 3, y - 4);
            ctx.save();
            ctx.translate(x, canvas.height - 5);
            ctx.rotate(-Math.PI / 4);
            ctx.fillText(label, 0, 0);
            ctx.restore();
        });
    }

    function renderRoomsTable(rooms) {
        const tbody = document.querySelector('#rooms-table tbody');
        if (!tbody) return;
        tbody.innerHTML = '';
        rooms.forEach(r => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td><input value="${r.name}" data-field="name"></td>
                <td>
                    <select data-field="type">
                        <option value="standard" ${r.type==='standard'?'selected':''}>standard</option>
                        <option value="deluxe" ${r.type==='deluxe'?'selected':''}>deluxe</option>
                        <option value="suite" ${r.type==='suite'?'selected':''}>suite</option>
                    </select>
                </td>
                <td><input type="number" value="${r.capacity}" data-field="capacity" style="width:80px;"></td>
                <td><input type="number" value="${r.pricePerNight}" data-field="pricePerNight" style="width:100px;"></td>
                <td>${r.needsCleaning ? 'Yes' : 'No'}</td>
                <td>
                    <button class="btn btn-secondary" data-action="save">Save</button>
                    <button class="btn btn-secondary" data-action="delete" style="margin-left:6px;">Delete</button>
                </td>
            `;
            // Wire actions
            tr.querySelector('[data-action="save"]').addEventListener('click', () => saveRoomRow(r._id, tr));
            tr.querySelector('[data-action="delete"]').addEventListener('click', () => deleteRoom(r._id));
            tbody.appendChild(tr);
        });
    }

    async function saveRoomRow(roomId, tr) {
        const token = localStorage.getItem('token');
        const payload = {};
        tr.querySelectorAll('input, select').forEach(el => {
            const field = el.getAttribute('data-field');
            if (field === 'capacity' || field === 'pricePerNight') {
                payload[field] = Number(el.value);
            } else {
                payload[field] = el.value;
            }
        });
        try {
            const res = await fetch(`${API_BASE}/api/rooms/${roomId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify(payload)
            });
            if (res.ok) {
                showMessage('Room saved.', 'success');
                loadAdminDashboard();
            } else {
                showMessage('Failed to save room.', 'error');
            }
        } catch {
            showMessage('Network error.', 'error');
        }
    }

    async function deleteRoom(roomId) {
        const token = localStorage.getItem('token');
        try {
            const res = await fetch(`${API_BASE}/api/rooms/${roomId}`, {
                method: 'DELETE',
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (res.ok) {
                showMessage('Room deleted.', 'success');
                loadAdminDashboard();
            } else {
                showMessage('Failed to delete room.', 'error');
            }
        } catch {
            showMessage('Network error.', 'error');
        }
    }
    async function createBooking(roomId, checkIn, checkOut, guests, contact, customers, selectedSubroom = '', idFiles = []) {
        const token = localStorage.getItem('token');
        
        // If not logged in, show login modal
        if (!token) {
            showMessage('Please login to make a booking.', 'error');
            showModal(loginModal);
            return { ok: false, message: 'Not authenticated' };
        }

        // Check if this is a temporary room (from HTML fallback)
        const isTemporaryRoom = roomId.startsWith('temp-');
        
        try {
            if (isTemporaryRoom) {
                // Handle temporary room (offline mode)
                console.log('Using temporary room data - backend not available');
                
                // Create a mock success response
                const mockBooking = {
                    _id: 'temp-booking-' + Date.now(),
                    roomId,
                    checkIn,
                    checkOut,
                    guests: parseInt(guests),
                    contact,
                    customers,
                    status: 'confirmed',
                    createdAt: new Date().toISOString(),
                    isTemporary: true
                };
                
                // Store in localStorage for offline access
                const userBookings = JSON.parse(localStorage.getItem('tempBookings') || '[]');
                userBookings.push(mockBooking);
                localStorage.setItem('tempBookings', JSON.stringify(userBookings));
                
                showMessage('Booking received! (Offline Mode)', 'success');
                hideModal(bookNowModal);
                return { 
                    ok: true, 
                    booking: mockBooking,
                    isTemporary: true,
                    message: 'Your booking has been received. Please note: This is an offline booking. Please check back later to confirm with the hotel.'
                };
            } else {
                // Handle real API call for non-temporary rooms
                const formData = new FormData();
                formData.append('roomId', roomId);
                formData.append('checkIn', checkIn);
                formData.append('checkOut', checkOut);
                formData.append('guests', String(guests));
                formData.append('contact', JSON.stringify(contact));
                formData.append('customers', JSON.stringify(customers));
                formData.append('selectedSubroom', selectedSubroom || '');
                idFiles.forEach((f, i) => formData.append('idProofs', f, f.name || `id_${i}.jpg`));

                const response = await fetch(`${API_BASE}/api/bookings`, {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${token}`
                    },
                    body: formData
                });

                if (response.status === 401) {
                    localStorage.removeItem('token');
                    showMessage('Session expired. Please login again.', 'error');
                    showModal(loginModal);
                    return { ok: false, message: 'Unauthorized' };
                }

                const data = await response.json().catch(() => ({}));
                
                if (!response.ok) {
                    showMessage(data.message || 'Booking failed. Please try again.', 'error');
                    return { 
                        ok: false, 
                        message: data.message || 'Booking failed. Please try again.' 
                    };
                }

                // If we get here, booking was successful
                showMessage('Booking successful!', 'success');
                hideModal(bookNowModal);
                return { 
                    ok: true, 
                    booking: data,
                    isTemporary: false
                };
            }
        } catch (error) {
            console.error('Booking error:', error);
            
            let errorMessage = 'An unexpected error occurred. Please try again.';
            
            if (error.name === 'TypeError' && error.message.includes('Failed to fetch')) {
                errorMessage = 'Unable to connect to the booking service. ';
                if (isTemporaryRoom) {
                    errorMessage += 'Your booking has been saved offline.';
                } else {
                    errorMessage += 'Please try again later or check your internet connection.';
                }
            }
            
            showMessage(errorMessage, 'error');
            return { 
                ok: false, 
                message: errorMessage,
                error: error.message
            };
        }
    }

    // Cancel booking function
    window.cancelBooking = async function(bookingId) {
        try {
            const token = localStorage.getItem('token');
            if (!token) {
                throw new Error('No authentication token found');
            }

            const res = await fetch(`${API_BASE}/api/bookings/${bookingId}/cancel`, {
                method: 'PATCH',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                }
            });

            if (res.status === 401) {
                localStorage.removeItem('token');
                showMessage('Session expired. Please login again.', 'error');
                if (typeof showModal === 'function') {
                    showModal(loginModal);
                }
                throw new Error('Unauthorized');
            }

            if (!res.ok) {
                const error = await res.json().catch(() => ({}));
                throw new Error(error.message || 'Failed to cancel booking');
            }

            const result = await res.json();
            showMessage('Booking cancelled successfully!', 'success');
            // Reload the page to reflect changes
            setTimeout(() => window.location.reload(), 1500);
            return result;
        } catch (error) {
            console.error('Error cancelling booking:', error);
            showMessage(error.message || 'Failed to cancel booking', 'error');
            throw error;
        }
    };

}); // Close the DOMContentLoaded event listener
